{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "gunicorn cit_app:app --workers 1 --timeout 300 --bind 0.0.0.0:$PORT",
    "healthcheckPath": "/api/data-status",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
